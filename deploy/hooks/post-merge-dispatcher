#!/bin/sh
#
# post-merge dispatcher
# Runs all executable scripts in deploy/hooks.d/post-merge/ in sorted order.
# A failing hook logs a warning but does NOT block subsequent hooks.

REPO_DIR="$(git rev-parse --show-toplevel)"
HOOKS_DIR="$REPO_DIR/deploy/hooks.d/post-merge"

if [ ! -d "$HOOKS_DIR" ]; then
    exit 0
fi

for hook in "$HOOKS_DIR"/*; do
    [ -x "$hook" ] || continue
    name="$(basename "$hook")"
    if ! "$hook" "$@"; then
        echo "Warning: post-merge hook '$name' failed (continuing)" >&2
    fi
done
