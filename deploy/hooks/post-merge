#!/usr/bin/env bash
set -euo pipefail

# Nexus Agent — post-merge hook
# Rebuilds and redeploys nexus-agent + TUI when Rust source changes.

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
RESET='\033[0m'

info()  { printf "${GREEN}nexus-agent: %s${RESET}\n" "$1"; }
skip()  { printf "${YELLOW}nexus-agent: %s${RESET}\n" "$1"; }
fail()  { printf "${RED}nexus-agent: %s${RESET}\n" "$1" >&2; exit 1; }

# ── Check for code changes ────────────────────────────────────────

if ! git diff-tree -r --name-only ORIG_HEAD HEAD | grep -qE '^(crates/|proto/|Cargo\.toml)'; then
    skip "no code changes, skipping rebuild"
    exit 0
fi

# ── Rebuild ───────────────────────────────────────────────────────

BIN_DIR="$HOME/.local/bin"
mkdir -p "$BIN_DIR"

info "rebuilding..."
START=$(date +%s)

if ! cargo build --release -p nexus-agent; then
    fail "agent build failed"
fi

if ! cargo build --release -p nexus-tui; then
    fail "TUI build failed"
fi

ELAPSED=$(( $(date +%s) - START ))
info "rebuilt in ${ELAPSED}s"

# ── Install binaries ──────────────────────────────────────────────

cp target/release/nexus-agent "$BIN_DIR/nexus-agent"
cp target/release/nexus "$BIN_DIR/nexus"
info "binaries installed to $BIN_DIR/"

# ── Restart service ───────────────────────────────────────────────

OS="$(uname -s)"
case "$OS" in
    Linux)
        systemctl --user restart nexus-agent 2>/dev/null || true
        info "systemd service restarted"
        ;;
    Darwin)
        launchctl kickstart -k "gui/$(id -u)/com.nexus.agent" 2>/dev/null || true
        info "launchd agent restarted"
        ;;
esac
