#!/usr/bin/env bash
set -euo pipefail

# Nexus Agent — pre-push hook
# Builds release on pushes to main. Aborts push on build failure.
# Skip with: SKIP_DEPLOY=1 git push

GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
RESET='\033[0m'

info()  { printf "${GREEN}nexus-agent: %s${RESET}\n" "$1"; }
skip()  { printf "${YELLOW}nexus-agent: %s${RESET}\n" "$1"; }
fail()  { printf "${RED}nexus-agent: %s${RESET}\n" "$1" >&2; exit 1; }

# ── Skip guard ────────────────────────────────────────────────────

if [[ "${SKIP_DEPLOY:-0}" == "1" ]]; then
    skip "SKIP_DEPLOY set, bypassing build"
    exit 0
fi

# ── Branch filter ─────────────────────────────────────────────────

PUSHING_MAIN=0
while read -r _local_ref _local_sha remote_ref _remote_sha; do
    if [[ "$remote_ref" == "refs/heads/main" ]]; then
        PUSHING_MAIN=1
        break
    fi
done

if [[ "$PUSHING_MAIN" -eq 0 ]]; then
    skip "not pushing to main, skipping build"
    exit 0
fi

# ── Build release ─────────────────────────────────────────────────

BIN_DIR="$HOME/.local/bin"
mkdir -p "$BIN_DIR"

info "building release..."
START=$(date +%s)

if ! cargo build --release; then
    fail "release build failed, push aborted"
fi

ELAPSED=$(( $(date +%s) - START ))
info "built in ${ELAPSED}s"

# ── Install binaries ──────────────────────────────────────────────

cp target/release/nexus-agent "$BIN_DIR/nexus-agent"
cp target/release/nexus "$BIN_DIR/nexus"
info "binaries installed to $BIN_DIR/"

# ── Restart service ───────────────────────────────────────────────

OS="$(uname -s)"
case "$OS" in
    Linux)
        systemctl --user restart nexus-agent 2>/dev/null || true
        info "systemd service restarted"
        ;;
    Darwin)
        launchctl kickstart -k "gui/$(id -u)/com.nexus.agent" 2>/dev/null || true
        info "launchd agent restarted"
        ;;
esac

info "deploy complete"
